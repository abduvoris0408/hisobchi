# ─────────────────────────────────────────────────────────
# HISOBCHI BACKEND — .env.example
# cp .env.example .env  →  keyin qiymatlarni to'ldiring
# ─────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001

# ── Supabase (bepul: supabase.com → New Project) ──────────
# Settings → Database → Connection string → "Session" mode
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres"

# Settings → API
SUPABASE_URL="https://[YOUR-REF].supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_KEY="eyJ..."

# ── JWT (ixtiyoriy matn, kamida 32 belgi) ─────────────────
JWT_ACCESS_SECRET="hisobchi-access-secret-kamida-32-belgi-1234567"
JWT_REFRESH_SECRET="hisobchi-refresh-secret-kamida-32-belgi-7654321"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Upstash Redis (bepul: upstash.com → Create Database) ──
# Connect → .env → UPSTASH_REDIS_REST_URL emas, balki:
# Connect → ioredis → URL (rediss:// bilan boshlanadi)
REDIS_URL="rediss://default:[PASSWORD]@[HOST].upstash.io:6379"

# ── Eskiz SMS (bepul 1000 ta: eskiz.uz) ───────────────────
# Development da SMS yuborilmaydi, OTP log da ko'rinadi
ESKIZ_EMAIL="email@example.com"
ESKIZ_PASSWORD="eskiz-parol"
ESKIZ_FROM="4546"

# ── Firebase FCM (ixtiyoriy — push notification uchun) ────
# console.firebase.google.com → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ── Telegram Bot (ixtiyoriy — @BotFather dan oling) ───────
TELEGRAM_BOT_TOKEN=""
# Production da to'ldiring (development da long polling ishlaydi)
TELEGRAM_WEBHOOK_URL=""
